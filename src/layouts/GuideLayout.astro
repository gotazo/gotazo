---
import "../styles/global.css";
import Navbar from "../components/ui/Navbar.astro";
import Footer from "../components/ui/Footer.astro";

/* ✅ clean + safe typing */
const { title, guides = [], related = [], headings = [] }: any = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body class="bg-black text-white">

    <!-- 🔝 NAVBAR -->
    <Navbar />

    <!-- 🧠 3 COLUMN LAYOUT -->
    <main class="max-w-7xl mx-auto px-4 py-16 grid lg:grid-cols-[260px_minmax(0,720px)_240px] gap-12">

      <!-- 📌 LEFT SIDEBAR (BIGGER TEXT) -->
      <aside class="hidden lg:block sticky top-24 h-fit">

        <p class="text-zinc-400 mb-4 uppercase tracking-wide text-xs">
          Guides
        </p>

        <ul class="space-y-3 text-[15px]"> <!-- ✅ bigger text -->

          {guides.map((g: any) => (
            <li>
              <a
                href={`/guides/${g.id}`}
                class="block text-zinc-400 hover:text-white transition leading-snug"
              >
                {g.data.title}
              </a>
            </li>
          ))}

        </ul>

        <!-- 🔥 TOOL CTA -->
        <div class="mt-10 p-4 bg-zinc-900 border border-zinc-800 rounded-xl">
          <p class="text-sm text-zinc-400 mb-2">
            Check before you buy
          </p>

          <a
            href="/tools/sofa-fit-calculator"
            class="text-sm text-indigo-400 hover:underline"
          >
            Use Sofa Fit Calculator →
          </a>
        </div>

      </aside>

      <!-- 📄 ARTICLE (MEDIUM STYLE) -->
      <article class="prose prose-invert max-w-3xl mx-auto
        text-[18px] leading-relaxed
        prose-headings:text-white prose-headings:font-semibold
        prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl
        prose-p:text-zinc-300
        prose-li:text-zinc-300
        prose-strong:text-white
        prose-a:text-indigo-400 prose-a:no-underline hover:prose-a:underline
      ">

        <h1>{title}</h1>

        <slot />

        <!-- 🔗 RELATED GUIDES -->
        {related.length > 0 && (
          <div class="mt-16 border-t border-zinc-800 pt-10">

            <h2>Related Guides</h2>

            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

              {related.map((g: any) => (
                <a
                  href={`/guides/${g.id}`}
                  class="group block bg-zinc-900/60 border border-zinc-800 p-5 rounded-xl transition hover:border-zinc-700 hover:shadow-lg"
                >
                  <h3 class="text-sm font-semibold group-hover:text-white">
                    {g.data.title}
                  </h3>

                  <p class="text-xs text-zinc-400 mt-2">
                    {g.data.description}
                  </p>

                  <div class="mt-3 text-xs text-zinc-500 flex justify-between">
                    <span class="capitalize">{g.data.category}</span>
                    <span class="group-hover:translate-x-1 transition">→</span>
                  </div>
                </a>
              ))}

            </div>

          </div>
        )}

      </article>

      <!-- 📚 RIGHT TOC (BIGGER TEXT) -->
      <aside class="hidden xl:block sticky top-24 h-fit">

        <p class="text-zinc-400 mb-4 uppercase tracking-wide text-xs">
          On this page
        </p>

        <ul class="space-y-3 text-[15px]"> <!-- ✅ bigger text -->

          {headings
            .filter((h: any) => h.depth === 2 || h.depth === 3)
            .map((h: any) => (
              <li class={h.depth === 3 ? "ml-4" : ""}>
                <a
                  href={`#${h.slug}`}
                  class="block text-zinc-400 hover:text-white transition leading-snug"
                >
                  {h.text}
                </a>
              </li>
          ))}

        </ul>

      </aside>

    </main>

    <!-- 🔻 FOOTER -->
    <Footer />

  </body>
</html>