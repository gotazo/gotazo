---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Sofa Fit Calculator">

<section class="py-24 max-w-3xl mx-auto">

  <!-- 🧠 TITLE -->
  <div class="text-center">
    <h1 class="text-4xl font-semibold">
      Sofa Fit Calculator
    </h1>
    <p class="mt-4 text-zinc-400">
      Check if your sofa fits your room before you buy.
    </p>
  </div>

  <!-- 🧩 CARD -->
  <div class="mt-12 bg-zinc-900 p-8 rounded-2xl shadow-xl">

    <!-- INPUTS -->
    <div class="grid gap-6">

      <div>
        <label class="text-sm text-zinc-400">Room Width (cm)</label>
        <input id="roomWidth" type="number" value="300"
          class="w-full mt-2 p-3 rounded-lg bg-zinc-800 border border-zinc-700" />
      </div>

      <div>
        <label class="text-sm text-zinc-400">Sofa Width (cm)</label>
        <input id="sofaWidth" type="number" value="180"
          class="w-full mt-2 p-3 rounded-lg bg-zinc-800 border border-zinc-700" />
      </div>

    </div>

    <!-- BUTTON -->
    <button onclick="calculateFit()" 
      class="mt-8 w-full py-3 rounded-xl bg-indigo-500 hover:bg-indigo-600 transition font-medium">
      Check Fit
    </button>

    <!-- 📊 VISUAL BAR -->
    <div class="mt-10">
      <div class="w-full h-4 bg-zinc-800 rounded-full overflow-hidden">
        <div id="spaceBar" class="h-full bg-indigo-500 transition-all duration-500" style="width: 0%"></div>
      </div>
    </div>

    <!-- RESULT -->
    <div id="result" class="mt-6 text-center text-lg"></div>

    <!-- 🧠 RECOMMENDATION -->
    <div id="recommendation" class="mt-3 text-center text-sm text-zinc-400"></div>

    <!-- 📏 TIP -->
    <p class="text-sm text-zinc-500 mt-4 text-center">
      Recommended: Keep at least 60–80 cm walking space.
    </p>

    <!-- 💰 CTA -->
    <div class="mt-6 text-center">
      <a href="/living-room/small-sofas" 
         class="inline-block px-6 py-3 bg-green-500 hover:bg-green-600 transition rounded-xl font-medium">
         View Sofas That Fit →
      </a>
    </div>

  </div>

</section>

<script>
  function calculateFit() {
    const roomWidthInput = document.getElementById('roomWidth') as HTMLInputElement | null;
    const sofaWidthInput = document.getElementById('sofaWidth') as HTMLInputElement | null;
    const resultDiv = document.getElementById('result') as HTMLElement | null;
    const recommendationDiv = document.getElementById('recommendation') as HTMLElement | null;
    const bar = document.getElementById('spaceBar') as HTMLElement | null;

    if (!roomWidthInput || !sofaWidthInput || !resultDiv || !recommendationDiv || !bar) {
      return;
    }

    const roomWidth = parseFloat(roomWidthInput.value);
    const sofaWidth = parseFloat(sofaWidthInput.value);

    if (!roomWidth || !sofaWidth) {
      resultDiv.innerHTML = "⚠️ Please fill all fields";
      recommendationDiv.innerHTML = "";
      bar.style.width = "0%";
      return;
    }

    const remaining = roomWidth - sofaWidth;
    const usedPercent = (sofaWidth / roomWidth) * 100;

    bar.style.width = usedPercent + "%";

    if (remaining >= 80) {
      resultDiv.innerHTML = `✅ Perfect fit — ${remaining} cm free space`;
      recommendationDiv.innerHTML = "Great choice! You’ll have plenty of walking space.";
    } 
    else if (remaining >= 60) {
      resultDiv.innerHTML = `✅ Good fit — ${remaining} cm space left`;
      recommendationDiv.innerHTML = "Comfortable, but avoid larger sofas.";
    } 
    else if (remaining >= 30) {
      resultDiv.innerHTML = `⚠️ Tight fit — only ${remaining} cm`;
      recommendationDiv.innerHTML = "Consider a smaller sofa for better movement.";
    } 
    else {
      resultDiv.innerHTML = `❌ Not recommended — only ${remaining} cm`;
      recommendationDiv.innerHTML = "This will feel cramped. Choose a compact sofa.";
    }
  }
</script>

</Layout>