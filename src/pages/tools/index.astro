---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Tools - Gotazo">

<section class="py-24 max-w-5xl mx-auto">

  <!-- 🧠 TITLE -->
  <div class="text-center">
    <h1 class="text-4xl font-semibold">
      Tools to Plan Your Space
    </h1>
    <p class="mt-4 text-zinc-400">
      Smart tools to help you choose the right furniture.
    </p>
  </div>

<!-- 🧩 TOOL GRID -->
<div class="mt-16 grid md:grid-cols-2 gap-6">

  <!-- SOFA TOOL -->
  <a href="/tools/sofa-fit-calculator" 
     class="bg-zinc-900 p-6 rounded-2xl hover:shadow-xl transition block">
     
    <h2 class="text-xl font-semibold">
      Sofa Fit Calculator
    </h2>

    <p class="text-zinc-400 mt-2">
      Check if your sofa fits your room before buying.
    </p>

    <span class="inline-block mt-4 text-indigo-400">
      Open Tool →
    </span>

  </a>

  <!-- BED TOOL (NEW) -->
  <a href="/tools/bed-size-calculator" 
     class="bg-zinc-900 p-6 rounded-2xl hover:shadow-xl transition block">
     
    <h2 class="text-xl font-semibold">
      Bed Size Calculator
    </h2>

    <p class="text-zinc-400 mt-2">
      Check if your bed fits your bedroom before buying.
    </p>

    <span class="inline-block mt-4 text-indigo-400">
      Open Tool →
    </span>

  </a>

</div>

</section>

</Layout>