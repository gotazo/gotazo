---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const guides = await getCollection("guides");
---

<Layout title="Guides">

<section class="py-20 max-w-6xl mx-auto px-4">

  <h1 class="text-4xl font-semibold text-center mb-12">
    Small Space Furniture Guides
  </h1>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

    {guides.map((g) => (
      <a
        href={`/guides/${g.id}`}
        class="group block rounded-2xl border border-zinc-800 bg-zinc-900/60 p-6 hover:border-zinc-700 transition"
      >
        <h2 class="text-lg font-semibold group-hover:text-white">
          {g.data.title}
        </h2>

        <p class="mt-2 text-sm text-zinc-400">
          {g.data.description}
        </p>

        <div class="mt-4 flex justify-between text-xs text-zinc-500">
          <span class="capitalize">{g.data.category}</span>
          <span class="group-hover:translate-x-1 transition">&rarr;</span>
        </div>
      </a>
    ))}

  </div>

</section>

</Layout>
