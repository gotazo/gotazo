---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Gotazo">

<!-- 🧠 HERO -->
<section class="py-28 text-center">

  <h1 class="text-5xl md:text-6xl font-semibold leading-tight tracking-tight">
    Furniture That Actually Fits Your Space
  </h1>

  <p class="mt-6 text-lg text-zinc-400 max-w-2xl mx-auto">
    Stop guessing dimensions. Compare, measure, and choose the right furniture for small homes.
  </p>

  <div class="mt-10 flex justify-center gap-4">
    <a href="/tools/sofa-fit-calculator"
       class="px-6 py-3 rounded-xl bg-indigo-500 hover:bg-indigo-600 transition">
      Check Sofa Fit
    </a>

    <a href="/guides"
       class="px-6 py-3 rounded-xl bg-zinc-800 hover:bg-zinc-700 transition">
      Explore Guides
    </a>
  </div>

</section>

<!-- 🔥 TOOL SECTION -->
<section class="py-20 max-w-5xl mx-auto text-center">

  <h2 class="text-3xl font-semibold">
    Start With the Right Fit
  </h2>

  <p class="mt-4 text-zinc-400">
    Our tools help you avoid costly furniture mistakes.
  </p>

  <div class="mt-8">
    <a href="/tools/sofa-fit-calculator"
       class="inline-block px-6 py-3 bg-indigo-500 rounded-xl">
       Use Sofa Fit Calculator →
    </a>
  </div>

</section>

<!-- 🛋️ CATEGORY SECTION -->
<section class="py-20 max-w-6xl mx-auto">

  <h2 class="text-3xl font-semibold text-center">
    Browse by Room
  </h2>

  <div class="mt-10 grid md:grid-cols-2 gap-8">

    <!-- Living Room -->
    <a href="/living-room" class="bg-zinc-900 p-8 rounded-2xl hover:shadow-xl transition">

      <h3 class="text-2xl font-semibold">
        Living Room
      </h3>

      <p class="text-zinc-400 mt-2">
        Sofas, coffee tables, and compact furniture.
      </p>

    </a>

    <!-- Guides -->
    <a href="/guides" class="bg-zinc-900 p-8 rounded-2xl hover:shadow-xl transition">

      <h3 class="text-2xl font-semibold">
        Buying Guides
      </h3>

      <p class="text-zinc-400 mt-2">
        Learn what to buy before you spend money.
      </p>

    </a>

  </div>

</section>

<!-- 💰 FEATURED CTA -->
<section class="py-24 text-center">

  <h2 class="text-3xl font-semibold">
    Find Sofas That Actually Fit
  </h2>

  <p class="mt-4 text-zinc-400">
    We curated the best sofas for small living rooms.
  </p>

  <div class="mt-8">
    <a href="/living-room/small-sofas"
       class="px-6 py-3 bg-green-500 rounded-xl hover:bg-green-600 transition">
       View Recommended Sofas →
    </a>
  </div>

</section>

</Layout>