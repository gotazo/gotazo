---
import Posts from "@/components/Posts.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import Pagination from "@/layouts/components/Pagination.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";

const posts = await getSinglePage("posts");
const sortedPosts = sortByDate(posts);
const totalPages = Math.ceil(posts.length / config.settings.pagination);
const currentPosts = sortedPosts.slice(0, config.settings.pagination);
---

<Base title="Gotazo | Smart Furniture Buying Guides">

<!-- HERO -->
<section class="hero-section text-center">
  <div class="container max-w-3xl">

    <h1 class="hero-title">
      Smart Furniture Buying Guides for Small Apartments
    </h1>

    <p class="hero-subtitle">
      Discover compact sofas, sofa cum beds, coffee tables, and space-saving
      furniture designed specifically for 1BHK and small apartment living.
    </p>

    <div class="hero-cta">
      <a href="/categories/living-room" class="btn btn-primary">
        Explore Sofa Guides
      </a>
    </div>

  </div>
</section>


<!-- FEATURED GUIDES -->
<section class="section">
  <div class="container">

    <h2 class="section-title text-center mb-8">
      Featured Buying Guides
    </h2>

    <div class="grid md:grid-cols-2 gap-8">

      <a href="/best-sofa-small-living-room" class="guide-card">
        <h3>Best Sofa for Small Living Room Under ₹20,000</h3>
        <p>
          Carefully selected compact sofas that fit small apartment living rooms
          without overcrowding your space.
        </p>
      </a>

      <a href="/best-sofa-cum-beds-1bhk" class="guide-card">
        <h3>Best Budget Sofa Cum Beds for 1BHK Apartments</h3>
        <p>
          Multi-functional sofa beds that save space and provide comfortable
          seating and sleeping in compact homes.
        </p>
      </a>

    </div>

  </div>
</section>


<!-- BROWSE CATEGORIES -->
<section class="section">
  <div class="container">

    <h2 class="section-title text-center mb-8">
      Browse Furniture Guides
    </h2>

    <div class="grid md:grid-cols-3 gap-8">

      <a href="/categories/living-room" class="category-card">
        <h3>Living Room</h3>
        <p>Sofas, sofa beds, coffee tables, and compact TV units.</p>
      </a>

      <a href="/categories/bedroom" class="category-card">
        <h3>Bedroom</h3>
        <p>Storage beds, compact wardrobes, and bedroom furniture.</p>
      </a>

      <a href="/categories/space-saving" class="category-card">
        <h3>Space Saving</h3>
        <p>Foldable furniture and multi-purpose solutions.</p>
      </a>

    </div>

  </div>
</section>


<!-- LATEST POSTS -->
<section class="section">
  <div class="container">

    <h2 class="section-title text-center mb-10">
      Latest Articles
    </h2>

    <Posts posts={currentPosts} className="mb-16" />
    <Pagination currentPage={1} totalPages={totalPages} />

  </div>
</section>

</Base>


<style>

.hero-section{
  background:#f0fbf9;
  padding:90px 20px;
  border-bottom:1px solid #e5e7eb;
}

.hero-title{
  font-size:42px;
  font-weight:700;
  margin-bottom:20px;
}

.hero-subtitle{
  font-size:18px;
  color:#666;
  max-width:650px;
  margin:auto;
}

.hero-cta{
  margin-top:30px;
}

.section-title{
  font-size:28px;
  font-weight:700;
}

/* guide cards */

.guide-card{
  padding:30px;
  border:1px solid #e5e7eb;
  border-radius:10px;
  transition:0.25s;
  display:block;
}

.guide-card:hover{
  box-shadow:0 10px 25px rgba(0,0,0,0.08);
  transform:translateY(-3px);
}

.guide-card h3{
  font-size:20px;
  font-weight:600;
  margin-bottom:10px;
}

/* category cards */

.category-card{
  padding:28px;
  border:1px solid #e5e7eb;
  border-radius:10px;
  display:block;
  transition:0.25s;
}

.category-card:hover{
  box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

.category-card h3{
  font-size:20px;
  font-weight:600;
  margin-bottom:10px;
}

</style>
