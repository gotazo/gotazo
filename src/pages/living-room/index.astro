---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const guides = (await getCollection("guides"))
  .filter((g) => g.data.category === "living-room");
---

<Layout title="Living Room">

<section class="py-24 max-w-6xl mx-auto px-4">

  <!-- 🧠 HEADER -->
  <div class="text-center mb-12">
    <h1 class="text-4xl font-semibold mb-4">
      Living Room Guides
    </h1>

    <p class="text-zinc-400 max-w-xl mx-auto">
      Furniture ideas, sizing guides, and recommendations for small living rooms.
    </p>
  </div>

  <!-- 💰 CTA -->
  <div class="mb-12 text-center">
    <a
      href="/living-room/small-sofas"
      class="inline-block px-6 py-3 bg-indigo-500 hover:bg-indigo-600 transition rounded-xl font-medium"
    >
      View Best Sofas →
    </a>
  </div>

  <!-- 📦 GRID -->
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

    {guides.map((g) => (
      <a
        href={`/guides/${g.id}`}
        class="group block bg-zinc-900/60 border border-zinc-800 p-6 rounded-2xl transition hover:border-zinc-700 hover:shadow-xl"
      >
        <h2 class="text-lg font-semibold group-hover:text-white">
          {g.data.title}
        </h2>

        <p class="text-zinc-400 mt-2 text-sm">
          {g.data.description}
        </p>

        <div class="mt-4 flex justify-between text-xs text-zinc-500">
          <span>Guide</span>
          <span class="group-hover:translate-x-1 transition">→</span>
        </div>
      </a>
    ))}

  </div>

</section>

</Layout>