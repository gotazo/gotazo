---
const {
  href = "#",
  variant = "primary",
  disabled = false,
  class: className = "",
} = Astro.props;

const isExternal = typeof href === "string" && href.startsWith("http");
const externalRel = "noopener noreferrer sponsored";

const base =
  "btn-smooth inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-indigo-400";

const styles = {
  primary:
    "bg-indigo-500 text-white hover:bg-indigo-400 active:bg-indigo-500/80 focus-visible:ring-indigo-300",
  secondary:
    "bg-zinc-800 text-slate-100 hover:bg-zinc-700 active:bg-zinc-600/90 focus-visible:ring-zinc-400",
};

const computed = `${base} ${
  styles[variant] ?? styles.primary
} ${disabled ? "opacity-50 cursor-not-allowed" : "hover:-translate-y-0.5"} ${className}`;
---

<a
  href={disabled ? undefined : href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? externalRel : undefined}
  class={computed}
  aria-disabled={disabled ? "true" : "false"}
>
  <slot />
</a>
