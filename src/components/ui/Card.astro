---
const { title, description, icon, class: className = "" } = Astro.props;
---

<article class={`card-surface p-6 transition-transform duration-300 transform hover:-translate-y-1 ${className}`}>
  <div class="flex items-center gap-3 mb-4">
    {icon ? <span class="text-indigo-300">{icon}</span> : null}
    <h3 class="text-xl font-semibold">{title}</h3>
  </div>
  <p class="text-slate-300 leading-relaxed">{description}</p>
</article>